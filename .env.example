# Get API_ID and API_HASH from https://my.telegram.org
API_ID=
API_HASH=

# Get from @BotFather
BOT_TOKEN=

# Generate with: python3 generate_session.py
SESSION_STRING=

# Your Telegram user id (numeric)
OWNER_ID=

# Comma separated list of extra admin user ids
SUDO_USERS=

# Optional: chat id where the bot posts logs
LOG_GROUP_ID=

# Optional: max track length in minutes
DURATION_LIMIT_MIN=120

# Optional: path to a yt-dlp cookies.txt file (helps avoid YouTube rate limits)
COOKIES_FILE=
